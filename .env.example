# ============================================
# LOGAN - WhatsApp Bot Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# POSTGRESQL DATABASE
# ============================================
# Railway: copy from your Postgres service > Connect > DATABASE_URL
# Local dev: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "false" to disable SSL for local development (Railway requires SSL)
# DATABASE_SSL=false

# ============================================
# API KEYS
# ============================================

# Groq API - For mention responses and voice transcription (Whisper)
# Get from: console.groq.com
GROQ_API_KEY=gsk_your_groq_key

# Anthropic API - For daily summaries (Claude)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Tavily API - For web search (Optional)
# Get from: tavily.com
TAVILY_API_KEY=tvly-your_tavily_key

# ElevenLabs API - For voice summaries (TTS) - Optional
# Get from: elevenlabs.io > Profile > API Keys
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=3JZUpoTOGG7akwuTH0DK

# ============================================
# BOT SETTINGS
# ============================================

# API server port
API_PORT=7700

# API authentication key (generate with: openssl rand -hex 32)
# Leave empty to disable authentication (not recommended for production)
API_KEY=change-this-to-secure-key

# Bot's WhatsApp phone number (without + or leading zeros)
# Example: 972501234567 (not +972-50-123-4567)
BOT_PHONE_NUMBER=

# Bot's LID (WhatsApp internal ID) - Usually auto-detected, set if needed
BOT_LID=

# ============================================
# DAILY SUMMARY
# ============================================

# Enable daily summary feature (true/false)
DAILY_SUMMARY_ENABLED=true

# Time to send daily summary (24h format, Israel timezone)
DAILY_SUMMARY_TIME=22:00

# Master channel for combined summary from all groups (optional)
# Set to channel ID (e.g., 120363296284758503@newsletter) to receive
# a unified summary of all group discussions after individual summaries
SUMMARY_MASTER_CHANNEL=

# ============================================
# SHABBAT SETTINGS
# ============================================

# Enable Shabbat auto lock/unlock (true/false)
SHABBAT_ENABLED=true

# Location for candle lighting times (geonameid)
# Jerusalem: 281184, Tel Aviv: 293397, Haifa: 294801
# Find more at: www.geonames.org
SHABBAT_LOCK_LOCATION=281184

# Location for havdalah times (can be different for later unlock)
SHABBAT_UNLOCK_LOCATION=294801

# Minutes relative to candle lighting for lock (negative = before)
SHABBAT_LOCK_OFFSET=-30

# Minutes relative to havdalah for unlock (positive = after)
SHABBAT_UNLOCK_OFFSET=30

# ============================================
# SPAM DETECTION
# ============================================

# Enable spam detection (LLM-based context analysis via Groq)
# Uses pre-filter + LLM classification. First offense = warning, second = removal.
SPAM_DETECTION_ENABLED=true

# Comma-separated phone numbers that are always exempt from spam actions
# Example: 972501234567,972509876543
SPAM_WHITELIST=

# ============================================
# JOIN REQUEST AUTO-PROCESSING
# ============================================

# Enable automatic processing of pending join requests (true/false)
# Bot must be admin in groups for this to work
AUTO_PROCESS_JOIN_REQUESTS=true

# Bot suspicion score threshold for auto-reject (0-5)
# Score >= 3 = likely bot, auto-reject
# Score < 3 = likely human, auto-approve if room available
# Scoring factors: no profile pic (+2), bot-like name (+2), suspicious phone (+1)
JOIN_REQUEST_BOT_THRESHOLD=3

# Maximum group size to enforce (default: 1024)
# Only approve requests if group hasn't reached this limit
MAX_GROUP_SIZE=1024

# Daily processing time (24h format, Israel timezone)
# Bot will check all groups for pending requests at this time daily (except Shabbat/Chag)
JOIN_REQUEST_PROCESS_TIME=09:00

# Comma-separated phone numbers that receive admin notifications about join request actions
# Uses SPAM_ADMIN_NOTIFY if not set separately
# Example: 972501234567,972509876543
JOIN_REQUEST_NOTIFY_ADMINS=

# ============================================
# WEBHOOK (Legacy - for Make.com integration)
# ============================================

# Optional webhook URL for mention notifications
MENTION_WEBHOOK_URL=
MENTION_API_KEY=

# ============================================
# ALLOWED GROUPS (Optional - if empty, monitors ALL groups)
# ============================================

# JSON array of groups to monitor
# Format: [{"id":"120363..@g.us","name":"Group Name"}]
# If not set, bot will monitor ALL groups it's added to
ALLOWED_GROUPS=

# ============================================
# ADMIN & AUTHORIZATION SETTINGS
# ============================================

# Comma-separated list of admin phone numbers (no + or dashes)
# Admins can use advanced features (agent, web search, tools) in any group
# Example: 972501234567,972509876543
AGENT_ADMIN_NUMBERS=
MENTION_ADMIN_NUMBERS=
TAVILY_ADMIN_NUMBERS=

# Groups where ALL users can use advanced features (comma-separated)
# Example: 120363419572967849@g.us,120363406852062417@g.us
AGENT_PUBLIC_GROUPS=
MENTION_PUBLIC_GROUPS=
TAVILY_PUBLIC_GROUPS=

# Groups where text chat with Logan is available to all (comma-separated)
# Tools/features still limited to admins or public groups
AGENT_FREE_CHAT_GROUPS=

# ADMIN_ONLY_MODE: Restrict bot to admins only (true/false)
# When enabled, only users in AGENT_ADMIN_NUMBERS can use the bot
ADMIN_ONLY_MODE=false

# ============================================
# COPILOT SDK AGENT (Advanced/Optional)
# ============================================

# Enable Copilot SDK Agent integration (true/false)
# ADVANCED FEATURE: Requires separate Copilot SDK Agent setup
# When enabled, certain triggers will route to the agent for:
# - Video generation (Remotion)
# - MCP server access (Obsidian, Tavily, Atlassian, etc.)
# - Shell command execution
# Most users should keep this DISABLED
COPILOT_AGENT_ENABLED=false

# URL where Copilot SDK Agent is running
# Default: http://localhost:4001
COPILOT_AGENT_URL=http://localhost:4001

# Request timeout in milliseconds (default: 120000 = 2 minutes)
# Video generation may take longer, increase if needed
COPILOT_AGENT_TIMEOUT=120000

# Path to the Copilot Agent's public folder (for video file resolution)
# Generated videos are returned as relative paths (e.g., /videos/video_xxx.mp4)
# This path is used to convert them to absolute paths for WhatsApp sending
# Example: /path/to/logan-copilot/public
COPILOT_AGENT_PUBLIC_PATH=

# ============================================
# LOGGING
# ============================================

# Log level (info, debug, warn, error)
LOG_LEVEL=info
