{
  "name": "whatsapp-logger",
  "version": "1.0.0",
  "description": "WhatsApp message logger using Baileys with Supabase storage",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc -w",
    "shavua-tov": "ts-node src/scripts/shavua-tov.ts",
    "manual-join-requests": "ts-node scripts/manual-join-request-check.ts",
    "debug-admin": "ts-node scripts/debug-admin-status.ts"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "supabase",
    "logger"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@whiskeysockets/baileys": "^6.7.21",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "node-schedule": "^2.1.1",
    "pino": "^8.17.2",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.39",
    "@types/node-schedule": "^2.1.8",
    "@types/qrcode-terminal": "^0.12.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
